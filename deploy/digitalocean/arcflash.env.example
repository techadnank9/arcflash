# This file is loaded by systemd, not by the browser bundle. Do not add VITE_
# secrets. In required mode the H key is held by NemoClaw's credential provider,
# so HAI_API_KEY must not be persisted here.
GRADIUM_API_KEY=gsk-your-key-here
PUBLIC_APP_URL=https://arcflash.example.com
HAI_REGION=eu
HCOMPUTER_AGENT=h/web-surfer-pro
HCOMPUTER_AGENT_ARTIFACT=hackathon-dnd
HCOMPUTER_ENABLED=true

NEMOCLAW_MODE=required
NEMOCLAW_SANDBOX=arcflash-copilot
NEMOCLAW_CREDENTIAL_NAME=arcflash-hcomputer
NEMOCLAW_WORKER_PATH=/sandbox/.openclaw/workspace/arcflash/worker/arcflash_h_worker.py
NEMOCLAW_EXEC_TIMEOUT_SECONDS=45
NEMOCLAW_STATUS_CACHE_SECONDS=5

PORT=8787
