{
  "name": "arcflash-copilot",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n WEB,API -c cyan,magenta \"vite --host 0.0.0.0\" \"uv run uvicorn arcflash_api.main:app --reload --reload-dir backend --port 8787\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "uv run uvicorn arcflash_api.main:app --reload --reload-dir backend --port 8787",
    "build": "tsc -b && vite build",
    "start": "uv run python -m arcflash_api",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:backend": "uv run pytest",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false",
    "qa:flow": "node scripts/qa-flow.mjs",
    "qa:electrisim": "node scripts/qa-electrisim.mjs",
    "engine:generate": "uv run python engine/generate_cv104_study.py",
    "setup:nemoclaw": "uv run python scripts/bootstrap_nemoclaw.py"
  },
  "dependencies": {
    "framer-motion": "^12.42.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "playwright-core": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
