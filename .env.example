# Keep this key server-side. Never prefix it with VITE_. Rotate any key shared
# in chat or logs before use. Required by the bootstrap command and by explicit
# direct-development mode; NemoClaw replaces it with a provider placeholder in
# the sandbox rather than exposing the real value to the Python worker.
HAI_API_KEY=hk-your-key-here

# Server-side Gradium speech-to-text key. The browser sends bounded WAV audio
# to FastAPI and never receives this value. Do not prefix it with VITE_.
GRADIUM_API_KEY=gsk-your-key-here

# H cloud browsers must be able to reach this URL. Use the deployed app URL.
PUBLIC_APP_URL=https://your-arcflash-copilot.example.com

# eu (default) or us
HAI_REGION=eu

# Official H browser agent. Override only with an agent available to your account.
HCOMPUTER_AGENT=h/web-surfer-holo3-1-35b

# Optional. Set to false to hide cloud execution in demo environments.
HCOMPUTER_ENABLED=true

# required (default): fail closed unless the controlled sandbox is ready
# preferred: use the sandbox when ready, otherwise the UI uses deterministic replay
# off: explicitly allow the host Python H adapter for local development
NEMOCLAW_MODE=required
NEMOCLAW_SANDBOX=arcflash-copilot
NEMOCLAW_CREDENTIAL_NAME=arcflash-hcomputer
NEMOCLAW_WORKER_PATH=/sandbox/.openclaw/workspace/arcflash/worker/arcflash_h_worker.py
NEMOCLAW_EXEC_TIMEOUT_SECONDS=45

PORT=8787
